# OpenAI Images (seeo Visual Generator)
# Create an API key at https://platform.openai.com/api-keys (same account as ChatGPT Plus/API billing).
# NEVER commit .env or real keys.

# Server-only: used by Vite dev proxy (not exposed to the browser bundle).
OPENAI_API_KEY=

# Image model. Default in code: gpt-image-2 (OpenAI Images API).
# See https://platform.openai.com/docs/guides/images
OPENAI_IMAGE_MODEL=gpt-image-2

# Draft generate/improve + optional vision for grounded images (Chat Completions).
# Default in code: gpt-5.5 (OpenAI API flagship; ChatGPT "GPT-5.5" is not a separate slug).
# No API model named gpt-5.6 — use gpt-5.5 or set a cheaper slug e.g. gpt-4.1.
# Allowlisted request body models: gpt-5.5, gpt-5.4-mini, gpt-5.4-nano, gpt-5, gpt-5-mini, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-4o, gpt-4o-mini
OPENAI_DRAFT_MODEL=gpt-5.5

# Optional: separate vision model for grounded image extraction (defaults to OPENAI_DRAFT_MODEL)
# OPENAI_GROUNDED_IMAGE_MODEL=gpt-5.5

# Optional production: origin of your image proxy (must expose POST /api/openai/images).
# Leave unset in local dev — requests go to the Vite dev server proxy.
# VITE_IMAGE_API_BASE_URL=https://your-app.example.com

# Optional production: origin for POST /api/generate/draft (draft improve loop).
# VITE_DRAFT_API_BASE_URL=https://your-app.example.com

# Convex (Grounded Context & Files) — from `npx convex dev` / Convex dashboard → Settings
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_URL=https://your-deployment.convex.cloud

# LinkedIn OAuth + posting (server-only; see docs/LINKEDIN_API.md)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5173/api/linkedin/callback
# mock | dry_run | live — default dry_run; never use live in staging unless intentional
LINKEDIN_POST_MODE=dry_run
# LINKEDIN_API_VERSION=202601
# Browser redirect after OAuth callback (defaults to / or VERCEL_URL)
LINKEDIN_APP_RETURN_URL=http://localhost:5173
# Optional production: if frontend and API share one origin, leave unset
# VITE_LINKEDIN_API_BASE_URL=https://your-app.vercel.app
