# OpenAI Images (seeo Visual Generator)
# Create an API key at https://platform.openai.com/api-keys (same account as ChatGPT Plus/API billing).
# NEVER commit .env or real keys.

# Server-only: used by Vite dev proxy (not exposed to the browser bundle).
OPENAI_API_KEY=

# Image model. Default in code: gpt-image-1 (OpenAI Images API).
# See https://platform.openai.com/docs/guides/images
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional production: origin of your image proxy (must expose POST /api/openai/images).
# Leave unset in local dev — requests go to the Vite dev server proxy.
# VITE_IMAGE_API_BASE_URL=https://your-app.example.com
